<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-vacancy-key-skill-table" author="comavp">
        <createTable tableName="vacancy_key_skill">
            <column name="key_skill_id" type="BIGINT"/>
            <column name="vacancy_id" type="BIGINT"/>
        </createTable>
    </changeSet>

    <changeSet id="002-add-vacancy-key-skill-foreign-keys" author="comavp">
        <addForeignKeyConstraint
                constraintName="fk_vacancy_key_skill_key_skill"
                baseTableName="vacancy_key_skill"
                baseColumnNames="key_skill_id"
                referencedTableName="key_skill"
                referencedColumnNames="id"
                onDelete="CASCADE"
                onUpdate="RESTRICT"/>
        <addForeignKeyConstraint
                constraintName="fk_vacancy_key_skill_vacancy"
                baseTableName="vacancy_key_skill"
                baseColumnNames="vacancy_id"
                referencedTableName="vacancy"
                referencedColumnNames="id"
                onDelete="CASCADE"
                onUpdate="RESTRICT"/>
    </changeSet>

</databaseChangeLog>
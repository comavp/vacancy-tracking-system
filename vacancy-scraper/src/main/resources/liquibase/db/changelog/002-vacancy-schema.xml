<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-vacancy-table" author="comavp">
        <createTable tableName="vacancy">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="url" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="archived" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="original_data" type="JSONB"/>
            <column name="employer_id" type="BIGINT"/>
        </createTable>
    </changeSet>

    <changeSet id="002-add-employer-id-foreign-key" author="comavp">
        <addForeignKeyConstraint
                constraintName="fk_vacancy_employer"
                baseTableName="vacancy"
                baseColumnNames="employer_id"
                referencedTableName="employer"
                referencedColumnNames="id"
                onDelete="CASCADE"
                onUpdate="RESTRICT"/>
    </changeSet>

    <changeSet id="003-add-original-id-column-to-vacancy" author="comavp">
        <addColumn tableName="vacancy">
            <column name="original_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>